  "term": "thm:trichotomy-on-peano-system",
  "kind": "Theorem",
  "title": "Trichotomy on a Peano System",
  "root": "",
  "statement": "Let $(P,S,1)$ be a Peano system. For every $a,b \\in P$, exactly one of the\nfollowing holds:\n\\[\na<b,\\qquad a=b,\\qquad b<a.\n\\]",
