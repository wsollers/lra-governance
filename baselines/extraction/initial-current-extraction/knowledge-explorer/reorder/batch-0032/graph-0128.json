  "section": "sets",
  "term": "thm:identity-absorption",
  "kind": "Theorem",
  "title": "Identity and Absorption Laws",
  "root": "",
  "statement": "Let $A,B$ be sets and $U$ a universe with $A \\subseteq U$. Then\n\\[\nA \\cup \\varnothing = A,\n\\qquad\nA \\cap U = A,\n\\]\n\\[\nA \\cup (A \\cap B) = A,\n\\qquad\nA \\cap (A \\cup B) = A.\n\\]",
