{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lra.local/schema/semantic-aliases.schema.json",
  "title": "LRA Semantic Alias Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "predicate_aliases"],
  "properties": {
    "schema_version": {
      "const": "lra.semantic-aliases/1.0"
    },
    "predicate_aliases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "source_predicate",
          "source_name",
          "source_surface_forms",
          "normalized_predicate",
          "normalized_name",
          "normalized_surface_forms",
          "grammatical_role",
          "logical_role",
          "allowed_fields",
          "reason"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^alias:[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "source_predicate": {
            "type": "string",
            "pattern": "^pred:[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "source_name": {
            "type": "string",
            "minLength": 1
          },
          "source_surface_forms": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "normalized_predicate": {
            "type": "string",
            "pattern": "^pred:[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "normalized_name": {
            "type": "string",
            "minLength": 1
          },
          "normalized_surface_forms": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "grammatical_role": {
            "enum": ["noun_phrase", "verb_phrase", "symbolic_operator", "macro_call", "unknown"]
          },
          "logical_role": {
            "enum": ["predicate", "object", "relation", "structure", "notation"]
          },
          "allowed_fields": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
