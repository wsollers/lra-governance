{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lra.local/schema/topic-semantic-audit.schema.json",
  "title": "LRA Topic Semantic Audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "topic",
    "source_baseline",
    "artifacts",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "const": "lra-topic-semantic-audit/1.0"
    },
    "topic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "branch",
        "volume",
        "chapter",
        "topic_id",
        "notes_directory",
        "governance_commit"
      ],
      "properties": {
        "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
        "branch": {"type": "string", "minLength": 1},
        "volume": {"type": "string", "pattern": "^volume-(i|ii|iii|iv|v|vi|vii|viii)$"},
        "book": {"type": ["string", "null"]},
        "chapter": {"type": "string", "minLength": 1},
        "topic_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "notes_directory": {"type": "string", "pattern": "(^|/)notes/[a-z0-9]+(?:-[a-z0-9]+)*/?$"},
        "governance_commit": {"$ref": "#/$defs/commit"},
        "started_at": {"type": ["string", "null"], "format": "date-time"},
        "completed_at": {"type": ["string", "null"], "format": "date-time"}
      }
    },
    "source_baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit", "router_closure_hash", "source_files"],
      "properties": {
        "commit": {"$ref": "#/$defs/commit"},
        "router_closure_hash": {"$ref": "#/$defs/sha256"},
        "source_files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "blob_sha"],
            "properties": {
              "path": {"type": "string", "minLength": 1},
              "blob_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
            }
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {"$ref": "#/$defs/artifactEntry"}
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inventory_count",
        "validated_count",
        "failed_count",
        "blocked_count",
        "source_restored",
        "final_validation_commit"
      ],
      "properties": {
        "inventory_count": {"type": "integer", "minimum": 0},
        "validated_count": {"type": "integer", "minimum": 0},
        "failed_count": {"type": "integer", "minimum": 0},
        "blocked_count": {"type": "integer", "minimum": 0},
        "source_restored": {"type": "boolean"},
        "final_validation_commit": {"anyOf": [{"$ref": "#/$defs/commit"}, {"type": "null"}]},
        "unresolved_labels": {
          "type": "array",
          "items": {"type": "string", "pattern": "^(def|ax|thm|lem|prop|cor):[a-z0-9]+(?:-[a-z0-9]+)*$"}
        }
      }
    }
  },
  "$defs": {
    "commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "status": {
      "enum": ["queued", "reviewed", "validated", "failed", "blocked"]
    },
    "result": {
      "enum": ["not_run", "pass", "pass_with_warnings", "fail", "blocked", "infrastructure_error"]
    },
    "artifactEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "order",
        "label",
        "kind",
        "title",
        "source_file",
        "review_directory",
        "status",
        "review_commit",
        "temporary_apply_commit",
        "revert_commit",
        "deterministic_result",
        "logic_result",
        "source_restored"
      ],
      "properties": {
        "order": {"type": "integer", "minimum": 1},
        "label": {"type": "string", "pattern": "^(def|ax|thm|lem|prop|cor):[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "kind": {"enum": ["definition", "axiom", "theorem", "lemma", "proposition", "corollary"]},
        "title": {"type": "string", "minLength": 1},
        "source_file": {"type": "string", "minLength": 1},
        "source_line_start": {"type": ["integer", "null"], "minimum": 1},
        "source_line_end": {"type": ["integer", "null"], "minimum": 1},
        "review_directory": {"type": "string", "pattern": "(^|/)notes/[a-z0-9-]+/(def|ax|thm|lem|prop|cor)-[a-z0-9-]+/?$"},
        "status": {"$ref": "#/$defs/status"},
        "review_commit": {"anyOf": [{"$ref": "#/$defs/commit"}, {"type": "null"}]},
        "temporary_apply_commit": {"anyOf": [{"$ref": "#/$defs/commit"}, {"type": "null"}]},
        "revert_commit": {"anyOf": [{"$ref": "#/$defs/commit"}, {"type": "null"}]},
        "deterministic_result": {"$ref": "#/$defs/result"},
        "logic_result": {"$ref": "#/$defs/result"},
        "source_restored": {"type": "boolean"},
        "blocking_issues": {"type": "array", "items": {"type": "string"}},
        "notes": {"type": ["string", "null"]}
      }
    }
  }
}
