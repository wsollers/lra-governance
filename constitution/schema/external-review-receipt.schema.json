{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://lra.local/schema/external-review-receipt.schema.json","title":"LRA External GPT Review Receipt","type":"object","additionalProperties":false,"required":["schema_version","reviewer","result","blocking_issues"],"properties":{"schema_version":{"const":"lra.external-review-receipt/1.0"},"reviewer":{"type":"object","additionalProperties":false,"required":["provider","role","requested_model","resolved_model","reasoning_effort","response_id","request_id","prompt","executor","input_sha256","output_sha256","started_at","completed_at","self_review"],"properties":{"provider":{"const":"openai_responses_api"},"role":{"enum":["semantic_reviewer","logic_validator"]},"requested_model":{"const":"gpt-5.6"},"resolved_model":{"type":"string","pattern":"^gpt-5\\.6-sol(?:[-.][A-Za-z0-9]+)*$"},"reasoning_effort":{"const":"high"},"response_id":{"type":"string","pattern":"^resp_[A-Za-z0-9_-]+$"},"request_id":{"type":["string","null"]},"prompt":{"type":"string","minLength":1},"executor":{"const":"tools/governance/invoke_external_gpt_reviewer.py"},"input_sha256":{"type":"string","pattern":"^sha256:[0-9a-f]{64}$"},"output_sha256":{"type":"string","pattern":"^sha256:[0-9a-f]{64}$"},"started_at":{"type":"string","format":"date-time"},"completed_at":{"type":"string","format":"date-time"},"self_review":{"const":false}}},"result":{"enum":["reviewed","blocked"]},"blocking_issues":{"type":"array","items":{"type":"string"}}}}